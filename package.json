{
  "name": "lizy14-ageomap-panel",
  "version": "0.1.0",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "e2e": "playwright test",
    "server": "docker compose up --build",
    "sign": "sign-plugin"
  },
  "author": "lizy14",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^10.0.0",
    "@grafana/plugin-e2e": "^3.6.1",
    "@grafana/sign-plugin": "^3.2.2",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.57.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.0",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^63.0.13",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-webpack-plugin": "^6.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.1.0",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.6.0",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.89.0",
    "sass-loader": "^16.0.0",
    "semver": "^7.7.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.3.0",
    "ts-node": "^10.9.0",
    "typescript": "5.9.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@grafana/data": "13.1.0",
    "@grafana/ui": "13.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "overrides": {
    "dompurify": "3.4.12",
    "js-cookie": "3.0.8",
    "uuid": "11.1.1"
  },
  "packageManager": "npm@11.13.0",
  "description": "Ageomap is a Grafana panel plugin for routes and markers on AMap (Gaode / 高德地图) vector maps.",
  "repository": {
    "type": "git",
    "url": "https://github.com/lizy14/ageomap"
  }
}
